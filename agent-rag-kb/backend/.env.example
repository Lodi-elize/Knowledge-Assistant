# ============================================
# Agent + RAG 个人知识库助手 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值

# --- LLM 提供商选择 ---
# 可选值: openai | deepseek | anthropic | ollama
LLM_PROVIDER=openai

# --- OpenAI 配置 (LLM_PROVIDER=openai 时必填) ---
OPENAI_API_KEY=sk-your-key-here
# LLM_MODEL_NAME=gpt-4o

# --- DeepSeek 配置 (LLM_PROVIDER=deepseek 时必填) ---
# DeepSeek API 兼容 OpenAI 格式，使用 ChatOpenAI + 自定义 base_url
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat

# --- Anthropic 配置 (LLM_PROVIDER=anthropic 时必填) ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_MODEL_NAME=claude-sonnet-4-6

# --- Ollama 配置 (LLM_PROVIDER=ollama 时必填) ---
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL_NAME=qwen2.5

# --- Embedding 提供商 ---
# 可选值: openai | huggingface
EMBEDDING_PROVIDER=openai

# --- OpenAI Embedding (EMBEDDING_PROVIDER=openai 时必填) ---
# EMBEDDING_MODEL=text-embedding-3-small

# --- HuggingFace 本地 Embedding (EMBEDDING_PROVIDER=huggingface 时使用) ---
# 免费，中文友好，首次加载会自动下载模型 (~100MB)
# 国内用户建议使用 HF_ENDPOINT 镜像加速
# HUGGINGFACE_MODEL_NAME=BAAI/bge-small-zh-v1.5
# HF_ENDPOINT=https://hf-mirror.com

# --- Chroma 向量库持久化路径 ---
CHROMA_PERSIST_DIR=./chroma_data

# --- LLM 温度 (0.0 = 最确定性，适合 Agent 工具决策) ---
LLM_TEMPERATURE=0.0
